{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Static Server",
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "-e",
        "const http=require('http'),fs=require('fs'),path=require('path'),root='/Users/prgrandmirage/Documents/Samabe/samabelinktree',types={'.html':'text/html; charset=utf-8','.css':'text/css','.js':'text/javascript','.json':'application/json','.png':'image/png','.jpg':'image/jpeg','.jpeg':'image/jpeg','.webp':'image/webp','.svg':'image/svg+xml','.ico':'image/x-icon'},port=process.env.PORT||5501;http.createServer((q,s)=>{let p=decodeURIComponent(q.url.split('?')[0]);if(p==='/'||p.endsWith('/'))p+='index.html';const f=path.join(root,p);fs.readFile(f,(e,d)=>{if(e){s.statusCode=404;s.end('Not found');return;}s.setHeader('Content-Type',types[path.extname(f).toLowerCase()]||'application/octet-stream');s.end(d);});}).listen(port,'0.0.0.0',()=>console.log('Static Server on http://localhost:'+port));"
      ],
      "port": 5501,
      "autoPort": true
    }
  ]
}
